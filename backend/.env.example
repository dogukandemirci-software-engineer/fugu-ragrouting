# Server
NODE_ENV=development
PORT=3001

# Database (Supabase local)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email — verification + password-reset delivery.
# EMAIL_ENABLED=false (default) logs the email + action link instead of sending,
# so local signup/reset flows work without an SMTP server. Set true in prod.
SMTP_HOST=localhost
SMTP_PORT=54325
SMTP_FROM=noreply@fugu.ai
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_ENABLED=false

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Frontend URL (for CORS and redirect links)
FRONTEND_URL=http://localhost:5173
