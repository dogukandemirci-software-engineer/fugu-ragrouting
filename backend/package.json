{
  "name": "fugu-backend",
  "version": "1.0.0",
  "description": "FUGU RAG Routing Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node -r ts-node/register migrations/run.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPatterns=unit",
    "test:integration": "jest --config jest.config.ts --testPathPatterns=integration --runInBand"
  },
  "dependencies": {
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "reflect-metadata": "^0.2.1",
    "stripe": "^14.9.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
